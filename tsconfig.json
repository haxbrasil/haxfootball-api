{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["bun"],
    "paths": {
      "@lib": ["./lib/index.ts"],
      "@lib/*": ["./lib/*"],
      "@/test/*": ["./test/*"],
      "@/*": ["./src/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "lib/**/*.ts", "test/**/*.ts", "drizzle.config.ts"]
}
