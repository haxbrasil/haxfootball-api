{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "root": true,
  "files": {
    "includes": [
      "**",
      "!node_modules",
      "!data",
      "!openapi.yaml",
      "!bun.lock",
      "!drizzle/meta/*.json",
      "!drizzle/*.sql"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": [
                  "@/features/**/*.contract",
                  "@/features/**/*.db",
                  "@/features/**/*.persistence",
                  "@/features/**/*.routes",
                  "@/features/**/*.service",
                  "@/features/**/*.util"
                ],
                "message": "Use the feature boundary files (`db.ts`, `http.ts`) or the standardized `_shared` structure instead of old suffix modules."
              }
            ]
          }
        }
      },
      "suspicious": {
        "noThenProperty": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "arrowParentheses": "always",
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "none"
    }
  },
  "json": {
    "formatter": {
      "trailingCommas": "none"
    }
  },
  "overrides": [
    {
      "includes": [
        "src/*.ts",
        "src/config/**/*.ts",
        "src/db/**/*.ts",
        "src/guards/**/*.ts",
        "src/plugins/**/*.ts",
        "scripts/**/*.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": [
                      "@/features/**/*.contract",
                      "@/features/**/*.db",
                      "@/features/**/*.persistence",
                      "@/features/**/*.routes",
                      "@/features/**/*.service",
                      "@/features/**/*.util"
                    ],
                    "message": "Use the feature boundary files (`db.ts`, `http.ts`) or the standardized `_shared` structure instead of old suffix modules."
                  },
                  {
                    "group": ["@/features/*/_shared/**"],
                    "message": "Feature `_shared` modules are private. Import from `@/features/<feature>/db`, `@/features/<feature>/http`, or a public operation folder instead."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/features/accounts/**/*.ts"],
      "linter": {
