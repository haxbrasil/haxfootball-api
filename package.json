{
  "name": "haxfootball-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "test": "bun run test:e2e && bun run test:internal",
    "test:e2e": "bun run test:e2e:boundaries && bash scripts/test-e2e.sh",
    "test:e2e:boundaries": "bun scripts/check-e2e-boundaries.ts",
    "test:internal": "bun test test/internal",
    "openapi:generate": "bun scripts/generate-openapi.ts",
    "openapi:check": "tmp_dir=$(mktemp -d); trap 'rm -rf \"$tmp_dir\"' EXIT; bun scripts/generate-openapi.ts \"$tmp_dir/openapi.yaml\" && diff -u openapi.yaml \"$tmp_dir/openapi.yaml\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@elysiajs/jwt": "^1.4.2",
    "@elysiajs/openapi": "^1.4.15",
    "@hax-brasil/replay-decoder": "^1.0.1",
    "@sinclair/typebox": "^0.34.49",
    "drizzle-orm": "~0.44.5",
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/bun": "^1.2.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "~0.31.4",
    "typescript": "^5.8.0",
    "yaml": "^2.9.0"
  }
}
